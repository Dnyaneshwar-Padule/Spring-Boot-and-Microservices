<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
 
 
 		<bean id="pdfReportGenerator" class="com.tca.beans.PdfReportGenerator" primary="true">
 		</bean>
 		
 		<bean id="excelReportGenerator" class="com.tca.beans.ExcelReportGenerator">
 		</bean>
 		
 		<bean id="reportManager" class="com.tca.beans.ReportManager" autowire="byType">
 			<property name="pages" value="100"/>
 		</bean>
 
        
 </beans>