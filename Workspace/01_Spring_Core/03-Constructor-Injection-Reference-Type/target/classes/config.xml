<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->

	<bean id="customer" class="com.tca.beans.Customer">
		<constructor-arg name="id" value="1001"/>
		<constructor-arg name="name" value="Aditya"/>
		<constructor-arg name="address" ref="address"/>
	</bean>
	
	<bean id="address" class="com.tca.beans.Address">
		<constructor-arg name="city" value="Pune"/>
		<constructor-arg name="pincode" value="411011"/>
	</bean>

</beans>